{
  "compilerOptions": {
    "lib": ["es2022"],
    "module": "nodenext",
    "target": "es6",
    "rootDir": "./src/",
    "outDir": "./dist/",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
